<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Launch/window theme only. The real UI styling lives in the Compose ProjectTheme.
      A branded window background avoids a white flash before Compose draws.
    -->
    <style name="Theme.Project" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/brand_orange</item>
        <item name="android:statusBarColor">@color/brand_orange_dark</item>
        <item name="android:navigationBarColor">@color/brand_orange_dark</item>
    </style>
</resources>
